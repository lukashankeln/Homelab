{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>bot/renovate"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.talos/version\\.txt$/"
      ],
      "matchStrings": [
        "TALOS_VERSION=(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "depNameTemplate": "ghcr.io/siderolabs/installer",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "argocd": {
    "managerFilePatterns": [
      "/applications/.+\\.yaml$/"
    ]
  },
  "helmv3": {
    "managerFilePatterns": [
      "/applications/.+\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        ".talos/version.txt"
      ],
      "postUpgradeTasks": {
        "commands": [
          ".talos/scripts/3-get-image.sh"
        ],
        "fileFilters": [
          ".talos/version.txt",
          ".talos/patches/**/disk.yaml"
        ],
        "executionMode": "branch"
      }
    },
    {
      "automerge": true,
      "matchPackageNames": [
        "/docker-registry.hankeln.work/*/"
      ]
    },
    {
      "automerge": true,
      "matchPackageNames": [
        "/renovate/renovate/"
      ]
    },
    {
      "groupName": "WebService",
      "groupSlug": "all webservice images",
      "matchPackageNames": [
        "/docker-registry.hankeln.work/webservice/*/"
      ]
    },
    {
      "matchPackageNames": [
        "ghcr.io/cloudnative-pg/postgresql"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ]
}
